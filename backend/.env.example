# Forge Runtime Environment Variables
# Copy this file to .env and fill in your values.

# === AI Provider (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# === AI Model for Workflow ===
# Default: nvidia/nemotron-3-ultra-550b-a55b:free (free tier)
# Alternatives: anthropic/claude-sonnet-4, openai/gpt-4o, etc.
FORGE_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# === Database ===
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
DATABASE_POOL_SIZE=10

# === VCS (GitHub) ===
GITHUB_TOKEN=ghp_your-github-token

# === Coding Tool ===
AIDER_MODEL=claude-sonnet-4-20250514

# === Sandbox ===
# auto = use Docker if available, never = direct subprocess, always = require Docker
FORGE_USE_SANDBOX=auto

# === Authentication ===
FORGE_API_TOKEN=your-secret-api-token-here
# Set to "true" to disable auth (development/testing only)
FORGE_AUTH_DISABLED=true

# === Runtime Settings ===
FORGE_ENV=development
FORGE_LOG_LEVEL=INFO
FORGE_CONFIG_DIR=./config

# === Session Defaults ===
SESSION_MAX_TOKENS=1000000

# === Workspace ===
WORKSPACE_BASE_DIR=/tmp/forge-workspaces
WORKSPACE_MAX_AGE_S=3600

# === Health Monitor ===
HEALTH_MONITOR_INTERVAL_S=30

# === Frontend WebSocket ===
# Set this in the frontend .env.local if backend runs on a different host
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
