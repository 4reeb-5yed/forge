# Forge Runtime Environment Variables
# Copy this file to .env and fill in your values.

# === AI Provider Keys ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# === Database ===
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
DATABASE_POOL_SIZE=10

# === VCS (GitHub) ===
GITHUB_TOKEN=ghp_your-github-token

# === Coding Tool ===
AIDER_MODEL=claude-sonnet-4-20250514

# === Runtime Settings ===
FORGE_ENV=development
FORGE_LOG_LEVEL=INFO
FORGE_CONFIG_DIR=./config

# === Session Defaults ===
SESSION_MAX_TOKENS=1000000
SESSION_MAX_COST_USD=50.00

# === Workspace ===
WORKSPACE_BASE_DIR=/tmp/forge-workspaces
WORKSPACE_MAX_AGE_S=3600

# === Authentication ===
FORGE_API_TOKEN=your-secret-api-token-here
# Set to "true" to disable auth (development/testing only)
FORGE_AUTH_DISABLED=false

# === Health Monitor ===
HEALTH_MONITOR_INTERVAL_S=30
HEALTH_PROBE_TIMEOUT_S=10
HEALTH_FAILURE_THRESHOLD=3
HEALTH_RECOVERY_THRESHOLD=2
